# SOC Dashboard Environment Variables
# Copy this file to .env.local and fill in the values

# ============ AUTHENTICATION ============
# Admin credentials for SOC Dashboard login
SOC_ADMIN_PASSWORD=<generate-a-unique-password>
SOC_ANALYST_PASSWORD=<generate-a-unique-password>

# JWT secret for token signing (generate a random 32+ character string)
JWT_SECRET=<generate-at-least-32-random-characters>

# ============ CORS ============
# Allowed origin for cross-origin requests
ALLOWED_ORIGIN=https://soc.pace.edu.vn

# ============ WAZUH API ============
# Wazuh Manager connection settings
WAZUH_MANAGER_URL=https://wazuh-manager.example.internal:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=your-wazuh-api-password-here
WAZUH_INDEXER_URL=https://wazuh-indexer.example.internal:9200
WAZUH_INDEXER_USER=soc-dashboard-readonly
WAZUH_INDEXER_PASSWORD=your-indexer-password-here
# Temporary emergency bypass for self-signed certificates: use 0.
# WARNING: 0 disables certificate and hostname verification for this Node.js container.
# Restore to 1 after configuring the Wazuh CA bundle.
NODE_TLS_REJECT_UNAUTHORIZED=1
# PEM bundle containing the CA certificates that signed both Wazuh API and Indexer certificates.
# Optional while NODE_TLS_REJECT_UNAUTHORIZED=0; defaults to the host system CA bundle.
WAZUH_CA_BUNDLE_HOST=/opt/soc-agent/secrets/wazuh-ca-bundle.pem

# ============ OPTIONAL ============
# Node environment
NODE_ENV=production
