# Copy this file to /opt/pace-soc/.env.production on the production VM.
# Never commit the real values.
SOC_ADMIN_PASSWORD=replace-with-a-long-random-password
SOC_ANALYST_PASSWORD=replace-with-a-long-random-password
JWT_SECRET=replace-with-at-least-32-random-characters

WAZUH_MANAGER_URL=https://wazuh-manager.internal:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=replace-me
WAZUH_INDEXER_URL=https://wazuh-indexer.internal:9200
WAZUH_INDEXER_USER=dashboard-reader
WAZUH_INDEXER_PASSWORD=replace-me

NODE_TLS_REJECT_UNAUTHORIZED=1
ACME_EMAIL=it@pace.edu.vn

